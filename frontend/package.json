{
  "name": "shiori-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings=0",
    "generate:api": "openapi-typescript ../openapi/openapi.json -o src/api/schema.d.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "pages:dev": "pnpm build && wrangler pages dev dist"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@tanstack/react-query": "^5.83.0",
    "jose": "^6.0.11",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260718.1",
    "@eslint/js": "^9.31.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.31.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^17.7.0",
    "jsdom": "^26.1.0",
    "openapi-typescript": "^7.8.0",
    "@types/node": "^24.0.15",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.37.0",
    "vite": "^7.0.5",
    "vitest": "^3.2.4",
    "wrangler": "^4.26.0"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  }
}
