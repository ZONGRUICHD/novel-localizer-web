SHIORI_ENV=production
SHIORI_DATABASE_URL=sqlite:////var/lib/shiori/db/shiori.sqlite3
SHIORI_DATA_DIR=/var/lib/shiori
SHIORI_PUBLIC_ORIGIN=https://translate.zongtech.xyz
SHIORI_OWNER_EMAIL=zongrui0831@outlook.com
SHIORI_ACCESS_TEAM_DOMAIN=https://REPLACE_ME.cloudflareaccess.com
SHIORI_ACCESS_AUDIENCE=REPLACE_FRONTEND_ACCESS_AUD
SHIORI_ORIGIN_ACCESS_AUDIENCE=REPLACE_ORIGIN_ACCESS_AUD
SHIORI_ACCESS_ALLOWED_IDPS=REPLACE_GITHUB_IDP_UUID,REPLACE_GOOGLE_IDP_UUID
SHIORI_ACCESS_VERIFIED_IDP_HEADER=Shiori-Verified-IdP
SHIORI_CSRF_SECRET_FILE=%d/shiori-csrf-secret
SHIORI_MASTER_KEY_FILE=%d/shiori-master-key
SHIORI_UPLOAD_MAX_BYTES=268435456
SHIORI_UPLOAD_CHUNK_SIZE=8388608
SHIORI_PROVIDER_TIMEOUT_SECONDS=20
SHIORI_LOG_LEVEL=INFO

# Non-secret restic settings are consumed only by shiori-backup.service.
RESTIC_REPOSITORY=s3:https://REPLACE_ACCOUNT_ID.r2.cloudflarestorage.com/shiori-restic-backup
